# LLM Configuration
# Set to "true" to use Ollama, "false" to use Fireworks API
USE_OLLAMA=true

# Ollama Configuration (when USE_OLLAMA=true)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.3:70b
OLLAMA_MAX_TOKENS=16384
OLLAMA_TEMPERATURE=0.1

# Fireworks API Configuration (when USE_OLLAMA=false)
# Get your API key from https://fireworks.ai/
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Recommended Ollama Models (install with: ollama pull <model>):
# - llama3.3:70b      (Best quality, requires ~40GB VRAM)
# - llama3.1:8b       (Good balance, requires ~8GB VRAM)
# - llama3.2:3b       (Fastest, requires ~3GB VRAM)
# - qwen2.5:14b       (Alternative high-quality option)
# - mistral:7b        (Another good alternative)
# - gemma2:9b         (Google's model)

# Example configurations for different setups:

# High-end setup (lots of VRAM):
# OLLAMA_MODEL=llama3.3:70b

# Mid-range setup:
# OLLAMA_MODEL=llama3.1:8b

# Low-resource setup:
# OLLAMA_MODEL=llama3.2:3b

# Custom Ollama server (if running on different machine):
# OLLAMA_BASE_URL=http://your-ollama-server:11434/v1